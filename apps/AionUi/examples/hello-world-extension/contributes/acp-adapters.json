    "healthCheck": {
      "versionCommand": "echo 1.0.0",
      "timeout": 3000
    }
  },
  {
    "id": "hello-http-agent",
    "name": "Hello HTTP Agent",
    "description": "A demo ACP adapter using HTTP transport",
    "connectionType": "http",
    "endpoint": "http://localhost:8080/acp",
