{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Sqlite": {
    "DbPath": "data/pty-agent.db",
    "LogsPath": "data/logs",
    "WorkdirsPath": "data/workdirs"
  },
  "Runtime": {
    "TerminalBackend": "auto",
    "PtyColumns": 160,
    "PtyRows": 40,
    "TerminalGatewayBaseUrl": "http://127.0.0.1:7300",
    "TerminalGatewayToken": "dev-terminal-token",
    "TerminalGatewayTimeoutMs": 5000
  },
  "Orchestration": {
    "EngineProvider": "maf"
  }
}
