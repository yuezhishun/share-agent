server {
    listen 80;
    server_name pty-slave.local;

    root /www/wwwroot/pty-agent-web-slave;
    index index.html;

    location = /healthz {
        return 200 "ok";
    }

    location ^~ /slave/web-pty/api/ {
        proxy_pass http://127.0.0.1:7320/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ^~ /api/ {
        proxy_pass http://127.0.0.1:7320/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ^~ /slave/web-pty/hubs/ {
        proxy_pass http://127.0.0.1:7320/hubs/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        proxy_buffering off;
    }

    location ^~ /slave/hubs/ {
        proxy_pass http://127.0.0.1:7320/hubs/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        proxy_buffering off;
    }

    location = / {
        return 302 /slave/;
    }

    location /slave/web-pty/ {
        rewrite ^/slave/web-pty/(.*)$ /$1 break;
        try_files $uri $uri/ /index.html;
    }

    location /slave/ {
        rewrite ^/slave/(.*)$ /$1 break;
        try_files $uri $uri/ /index.html;
    }
}
